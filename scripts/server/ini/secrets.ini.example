# Bybit API credentials — copy this file to secrets.ini and fill in your keys.
# secrets.ini is excluded from git (.gitignore).
#
# Each section corresponds to one Bybit account/profile.
# The active profile is selected via BYBIT_ACTIVE_PROFILE (SQLite config or env var).
# Default active profile: demo
#
# Section naming: [bybit_<profile_name>]
#   demo  — API keys from bybit.com → Demo Trading (NOT testnet.bybit.com)
#   live  — API keys from bybit.com → Live Trading
#   sub1  — Sub-account #1 (optional)

[bybit_demo]
api_key    = YOUR_DEMO_API_KEY
api_secret = YOUR_DEMO_API_SECRET

[bybit_live]
api_key    = YOUR_LIVE_API_KEY
api_secret = YOUR_LIVE_API_SECRET

# [bybit_sub1]
# api_key    = YOUR_SUB1_API_KEY
# api_secret = YOUR_SUB1_API_SECRET
